# buddy — environment configuration
# Copy to .env and fill in your values.

# ── Anthropic (optional) ──────────────────────────────────────────────────────
# Enables Claude Opus 4.7 escalation + Haiku grading with extended thinking.
# Without this key buddy runs 100% locally on Ollama — no external calls.
ANTHROPIC_API_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Global API key — protects all non-public endpoints when set.
# Pass as:  X-API-Key: <value>  OR  Authorization: Bearer <value>
# Leave empty for local / trusted-network installs (no auth enforced).
API_KEY=

# Admin token — additionally protects /admin/* endpoints.
ADMIN_TOKEN=

# ── Models ────────────────────────────────────────────────────────────────────
# Conductor: the tool-calling model.  Auto-upgrades to qwen3:14b if installed.
CONDUCTOR_MODEL=qwen2.5:14b
LOCAL_MODEL=qwen2.5:14b
FALLBACK_LOCAL_MODEL=phi4-mini

# ── Agent ─────────────────────────────────────────────────────────────────────
MAX_AGENT_ITERATIONS=6
USE_AGENT_LOOP=true
AGENT_TIMEOUT_SECONDS=300
# Comma-separated list of tools to disable at startup (toggleable at runtime too)
# DISABLED_TOOLS=shell_execute,run_python
DISABLED_TOOLS=

# ── Web search ────────────────────────────────────────────────────────────────
# Optional: enables full Brave Search results (falls back to DuckDuckGo when empty)
BRAVE_SEARCH_API_KEY=

# ── Infrastructure ────────────────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
FOREST_HOST=http://127.0.0.1:7438
PORT=7437
DEBUG=false

# ── Storage / UX ──────────────────────────────────────────────────────────────
# VAULT_PATH=/path/to/your/vault   # default: ~/BuddyVault
CHAT_HISTORY_LIMIT=20
