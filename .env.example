ANTHROPIC_API_KEY=your-key-here
LOCAL_MODEL=qwen2.5:14b
FALLBACK_LOCAL_MODEL=phi4-mini
OLLAMA_HOST=http://127.0.0.1:11434
PORT=7437
DEBUG=false
# Set a secret value to protect /admin/* endpoints.
# Leave blank (default) for local-only installs.
ADMIN_TOKEN=
CHAT_HISTORY_LIMIT=20
# Agent conductor model. Upgrade: ollama pull qwen3:14b then set below.
CONDUCTOR_MODEL=qwen2.5:14b
MAX_AGENT_ITERATIONS=6
USE_AGENT_LOOP=true
# Hard timeout for a single agent run (seconds). Default: 300
AGENT_TIMEOUT_SECONDS=300
# Comma-separated list of tool names to disable. Example: shell_execute,run_python
DISABLED_TOOLS=
# Brave Search API key for full web results (optional, falls back to DuckDuckGo)
BRAVE_SEARCH_API_KEY=
